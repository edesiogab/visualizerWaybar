"custom/audio_visualizer": {
  "exec": "~/.local/bin/waybar-audio-visualizer --interval-ms 90 --bands 18 --backend auto --cava-source auto --show-title --title-max-len 22 --title-scroll-every 6",
  "return-type": "json",
  "format": "{text}",
  "on-click": "~/.local/bin/waybar-audio-visualizer --toggle-playback",
  "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
  "tooltip": true
}
